# Smart Parking University
PROJECT_NAME=smart-campus-parking
ENVIRONMENT=local
CORS_ALLOW_ORIGINS=*

# Main transactional database
POSTGRES_CORE_DB=parking_core
POSTGRES_CORE_USER=parking_user
POSTGRES_CORE_PASSWORD=parking_pass
POSTGRES_CORE_PORT=5432
POSTGRES_CORE_INTERNAL_PORT=5432

# Biometric database
POSTGRES_BIOMETRICS_DB=parking_biometrics
POSTGRES_BIOMETRICS_USER=biometric_user
POSTGRES_BIOMETRICS_PASSWORD=biometric_pass
POSTGRES_BIOMETRICS_PORT=5433
POSTGRES_BIOMETRICS_INTERNAL_PORT=5432

# Object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=parking-raw-images
MINIO_BUCKET_PROCESSED=parking-processed-images
MINIO_BUCKET_FACES=parking-faces
MINIO_BUCKET_PLATES=parking-plates
MINIO_BUCKET_EVIDENCE=parking-evidence
MINIO_BUCKET_TEMP=parking-temp
EVIDENCE_DEFAULT_UNIVERSITY_ID=00000000-0000-0000-0000-000000000001

# MQTT
MQTT_PORT=1883
MQTT_WS_PORT=9002
MQTT_HOST=mosquitto
MQTT_QOS=0
MQTT_KEEPALIVE=60
MQTT_USERNAME=
MQTT_PASSWORD=
IOT_ENABLED=true
IOT_GATE_DEFAULT_ID=garita-01
IOT_GATE_COMMAND_TOPIC=ucepark/garita/comandos
IOT_GATE_EVENT_TOPIC=ucepark/garita/eventos

# garita-controller (deteccion de placa en vivo, ver backend/services/garita-controller/garita_controller.py)
# IMPORTANTE: dentro de Docker solo funciona una camara IP (RTSP/HTTP), no un
# indice de webcam USB - Docker Desktop en Windows no tiene paso de
# dispositivos USB a contenedores. Reemplaza el valor de abajo por la URL
# real de tu camara, ej: rtsp://usuario:clave@192.168.1.50:554/stream1
PLATE_CAMERA_SOURCE=0
GARITA_SHOW_WINDOW=false
# Atajos opcionales que aparecen como botones en la vista en vivo
# (http://<host>:8010/). Vacio = no se muestra el boton correspondiente.
PLATE_CAMERA_PRESET_IP_LABEL=Camara IP
PLATE_CAMERA_PRESET_IP=
PLATE_CAMERA_PRESET_USB_LABEL=Webcam USB (puente local)
PLATE_CAMERA_PRESET_USB=

# Node-RED
NODERED_PORT=1880

# Backend mock services
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
UNIVERSITY_SERVICE_PORT=8002
VEHICLE_SERVICE_PORT=8003
PARKING_SERVICE_PORT=8004
FACE_SERVICE_PORT=8005
PLATE_SERVICE_PORT=8006
PAYMENT_SERVICE_PORT=8007
IOT_SERVICE_PORT=8008
AUDIT_SERVICE_PORT=8009
GARITA_CONTROLLER_PORT=8010
PAYMENT_GRACE_MINUTES=15

# AI service modes
PLATE_SERVICE_MODE=hybrid
PLATE_DETECTION_MODE=hybrid
PLATE_DEFAULT_COUNTRY_CODE=EC
PLATE_MIN_CONFIDENCE=0.70
PLATE_PATTERN_REGEX=^[A-Z]{3}\d{3,4}$
PLATE_DETECTOR_MODEL_PATH=models/plate_detector.pt
PLATE_OCR_PREFERRED_ENGINE=rapidocr
PLATE_DETECTOR_CONFIDENCE=0.30
PLATE_DETECTOR_IMGSZ=320
PLATE_DETECTOR_MAX_DETECTIONS=1
PLATE_DETECTOR_DEVICE=cpu
PLATE_PREPROCESS_RESIZE_FACTOR=1.5
PLATE_PREPROCESS_MAX_WIDTH=960
PLATE_DEBUG_OUTPUT_DIR=/tmp/plate-debug
PLATE_QUALITY_MIN_WIDTH=640
PLATE_QUALITY_MIN_HEIGHT=360
PLATE_QUALITY_MIN_SCORE=0.45
FACE_SERVICE_MODE=hybrid
FACE_REAL_PROVIDER=insightface
FACE_SIMILARITY_THRESHOLD=0.82
FACE_LIVENESS_THRESHOLD=0.75
FACE_EMBEDDING_DIMENSIONS=512
FACE_DEFAULT_BUCKET=parking-faces
FACE_DETECTOR_CONFIDENCE_THRESHOLD=0.35
FACE_QUALITY_THRESHOLD=0.45
FACE_INSIGHTFACE_APP_NAME=buffalo_l
FACE_INSIGHTFACE_ROOT=/tmp/insightface
# Alternate provider example:
# FACE_REAL_PROVIDER=face_recognition
# FACE_SIMILARITY_THRESHOLD=0.60
# FACE_EMBEDDING_DIMENSIONS=128

# Security
JWT_SECRET_KEY=change-this-jwt-secret-in-production
JWT_ISSUER=smart-parking-university
JWT_AUDIENCE=smart-parking-clients
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
AUDIT_ENABLED=true
AUDIT_INTERNAL_KEY=change-this-audit-key-in-production
AUDIT_SERVICE_URL=http://audit-service:8000

# Service integration
IOT_SERVICE_URL=http://iot-service:8000
PARKING_SERVICE_URL=http://parking-service:8000
VEHICLE_SERVICE_URL=http://vehicle-service:8000
FACE_SERVICE_URL=http://face-service:8000
PLATE_SERVICE_URL=http://plate-service:8000
PAYMENT_SERVICE_URL=http://payment-service:8000
MINIO_INTERNAL_URL=http://minio:9000
DOWNSTREAM_DEFAULT_TIMEOUT_SECONDS=10
DOWNSTREAM_PLATE_TIMEOUT_SECONDS=180
DOWNSTREAM_EVIDENCE_TIMEOUT_SECONDS=20
