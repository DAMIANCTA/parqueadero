# IMPORTANTE: para probar en un telefono real con Expo Go, este valor debe
# ser la IP de LAN de la maquina donde corre el api-gateway (puerto 8000),
# no localhost/127.0.0.1 (el telefono no puede resolver eso a tu PC).
# Ejemplo: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.184:8000
EXPO_PUBLIC_API_BASE_URL=
