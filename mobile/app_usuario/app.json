{
  "expo": {
    "name": "app_usuario",
    "slug": "app_usuario",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ucepark.appusuario",
      "infoPlist": {
        "NSCameraUsageDescription": "UCEPark necesita acceder a tu cámara para verificar tu rostro en la garita."
      }
    },
    "android": {
      "package": "com.ucepark.appusuario",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "UCEPark necesita acceder a tu cámara para verificar tu rostro en la garita."
        }
      ]
    ]
  }
}
